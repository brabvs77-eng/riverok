---
import { clubConfig } from '../lib/club.config';
import type { Translations } from '../lib/i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="tournaments" class="py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <a
      href={clubConfig.tournamentScheduleUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-track="ViewContent"
      class="group flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-6 lg:p-8 bg-gradient-to-r from-indigo-700 to-indigo-900 rounded-2xl text-white hover:shadow-xl hover:shadow-indigo-300/30 transition-all"
    >
      <div class="flex items-start gap-4">
        <span class="shrink-0 px-3 py-1 bg-orange-500 text-white text-xs font-bold uppercase tracking-wider rounded-full">
          {t.tournament.badge}
        </span>
        <div>
          <h2 class="font-serif text-xl lg:text-2xl font-bold mb-1">{t.tournament.title}</h2>
          <p class="text-indigo-200 text-sm lg:text-base">{t.tournament.description}</p>
        </div>
      </div>
      <span class="inline-flex items-center gap-2 px-6 py-3 bg-white text-indigo-700 font-semibold rounded-full group-hover:bg-orange-50 transition-colors shrink-0">
        {t.tournament.cta}
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </a>
  </div>
</section>
