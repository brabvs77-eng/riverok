---
import { clubConfig } from '../lib/club.config';
import type { Translations } from '../lib/i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const icons = ['📱', '🏛️', '🎯'];
---

<section id="how-to-start" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <h2 class="font-serif text-3xl lg:text-4xl font-bold text-river-text mb-4">{t.howToStart.title}</h2>
      <p class="text-lg text-river-muted">{t.howToStart.subtitle}</p>
    </div>

    <div class="relative">
      <div class="hidden lg:block absolute top-12 left-0 right-0 h-0.5 bg-river-border" style="margin-left: 10%; margin-right: 10%;"></div>

      <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
        {
          t.howToStart.steps.map((step, i) => (
            <div class="relative reveal" style={`animation-delay: ${i * 0.15}s`}>
              <div class="flex items-center gap-4 mb-6">
                <div class="relative z-10 flex items-center justify-center w-12 h-12 bg-river-accent text-river-bg font-serif text-lg font-bold rounded-full">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <span class="text-2xl">{icons[i]}</span>
              </div>
              <h3 class="font-serif text-xl font-bold text-river-text mb-3">{step.title}</h3>
              <p class="text-river-muted leading-relaxed">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="flex flex-wrap gap-4 mt-14">
      <a
        href={clubConfig.stores.appStore}
        target="_blank"
        rel="noopener noreferrer"
        data-track="CompleteRegistration"
        class="inline-flex items-center gap-3 px-6 py-3 card rounded-xl hover:border-river-accent/50 transition-colors"
      >
        <svg class="w-6 h-6 text-river-accent" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
        <div class="text-left">
          <p class="text-xs text-river-muted">Download on the</p>
          <p class="font-semibold text-river-text">{t.howToStart.appStore}</p>
        </div>
      </a>
      <a
        href={clubConfig.stores.googlePlay}
        target="_blank"
        rel="noopener noreferrer"
        data-track="CompleteRegistration"
        class="inline-flex items-center gap-3 px-6 py-3 card rounded-xl hover:border-river-accent/50 transition-colors"
      >
        <svg class="w-6 h-6 text-river-accent" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a1.002 1.002 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
        </svg>
        <div class="text-left">
          <p class="text-xs text-river-muted">Get it on</p>
          <p class="font-semibold text-river-text">{t.howToStart.googlePlay}</p>
        </div>
      </a>
      <a
        href={clubConfig.stores.windows}
        target="_blank"
        rel="noopener noreferrer"
        data-track="CompleteRegistration"
        class="inline-flex items-center gap-3 px-6 py-3 card rounded-xl hover:border-river-accent/50 transition-colors"
      >
        <svg class="w-6 h-6 text-river-accent" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 5.5L10.5 4.1v7.6H3V5.5zm0 8.3h7.5v7.6L3 19.9V13.8zm9-9.4L21 3.1v7.5h-9V4.4zm0 8.4h9v7.5l-9 1.6V12.8z" />
        </svg>
        <div class="text-left">
          <p class="text-xs text-river-muted">Download for</p>
          <p class="font-semibold text-river-text">{t.howToStart.windows}</p>
        </div>
      </a>
      <a
        href={clubConfig.stores.macOS}
        target="_blank"
        rel="noopener noreferrer"
        data-track="CompleteRegistration"
        class="inline-flex items-center gap-3 px-6 py-3 card rounded-xl hover:border-river-accent/50 transition-colors"
      >
        <svg class="w-6 h-6 text-river-accent" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
        <div class="text-left">
          <p class="text-xs text-river-muted">Download for</p>
          <p class="font-semibold text-river-text">{t.howToStart.macOS}</p>
        </div>
      </a>
    </div>
  </div>
</section>
