---
import { clubConfig } from '../lib/club.config';
import type { Translations } from '../lib/i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const banks = [...clubConfig.banks, ...clubConfig.banks];
---

<section class="py-12 border-y border-stone-200 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-6">
    <p class="text-sm font-semibold text-stone-500 uppercase tracking-widest text-center">{t.banks.title}</p>
  </div>
  <div class="relative">
    <div class="flex animate-marquee whitespace-nowrap">
      {
        banks.map((bank) => (
          <div class="inline-flex items-center gap-3 mx-8 px-6 py-3 bg-white border border-stone-200 rounded-full">
            <span class="w-10 h-10 flex items-center justify-center bg-indigo-50 text-indigo-700 font-bold text-xs rounded-full">
              {bank.code}
            </span>
            <span class="font-medium text-stone-700">{bank.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
