---
import { clubConfig } from '../lib/club.config';
import type { Translations } from '../lib/i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 bg-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <img
          src="/logo.jpg"
          alt="Riverok Club"
          class="h-12 w-12 rounded-lg object-cover"
          width="48"
          height="48"
        />
      </div>

      <p class="text-sm text-stone-500 text-center max-w-md">{t.footer.disclaimer}</p>

      <div class="flex items-center gap-4">
        <a
          href={clubConfig.telegram.botUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-stone-400 hover:text-indigo-700 transition-colors"
          aria-label="Telegram Bot"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.693-1.653-1.124-2.678-1.8-1.185-.781-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.062 3.345-.479.329-.913.489-1.302.481-.428-.008-1.252-.241-1.865-.44-.752-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.14.121.099.154.232.17.326.015.094.034.308.019.475z" />
          </svg>
        </a>
        <span class="text-xs text-stone-400">Club ID: {clubConfig.clubId}</span>
      </div>
    </div>

    <p class="text-center text-xs text-stone-400 mt-8">
      © {year} Riverok Club. {t.footer.rights}
    </p>
  </div>
</footer>
