---
import { clubConfig } from '../lib/club.config';
import type { Translations } from '../lib/i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="deposit" class="py-20 lg:py-28 bg-river-surface/50 border-y border-river-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <h2 class="font-serif text-3xl lg:text-4xl font-bold text-river-text mb-4">{t.deposit.title}</h2>
        <p class="text-lg text-river-muted mb-8">{t.deposit.subtitle}</p>

        <ol class="space-y-4 mb-8">
          {
            t.deposit.steps.map((step, i) => (
              <li class="flex items-start gap-4">
                <span class="shrink-0 w-8 h-8 flex items-center justify-center bg-river-bg-light text-river-accent text-sm font-bold rounded-full border border-river-border">
                  {i + 1}
                </span>
                <span class="text-river-muted pt-1">{step}</span>
              </li>
            ))
          }
        </ol>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={clubConfig.telegram.botUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="InitiateCheckout"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 btn-primary rounded-full"
          >
            {t.deposit.openBot}
          </a>
          <a
            href={clubConfig.telegram.managerUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="Lead"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 btn-outline rounded-full"
          >
            {t.deposit.writeManager}
          </a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="grid sm:grid-cols-3 gap-4 mb-8">
          <div class="p-5 card rounded-2xl text-center">
            <p class="text-2xl mb-2">⏱️</p>
            <p class="text-sm font-semibold text-river-text">{t.deposit.fast}</p>
          </div>
          <div class="p-5 card rounded-2xl text-center">
            <p class="text-2xl mb-2">🔒</p>
            <p class="text-sm font-semibold text-river-text">{t.deposit.ssl}</p>
          </div>
          <div class="p-5 card rounded-2xl text-center">
            <p class="text-2xl mb-2">⚡</p>
            <p class="text-sm font-semibold text-river-text">{t.deposit.instant}</p>
          </div>
        </div>

        <div class="card-elevated rounded-3xl p-8 lg:p-10">
          <div class="flex flex-col sm:flex-row items-center gap-8">
            <div class="shrink-0 p-4 bg-white rounded-2xl shadow-lg">
              <img
                src={`https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${encodeURIComponent(clubConfig.telegram.botUrl)}`}
                alt="Telegram Bot QR"
                width="160"
                height="160"
                class="rounded-lg"
                loading="lazy"
              />
            </div>
            <div class="text-center sm:text-left">
              <p class="text-sm font-semibold text-river-accent mb-2">Telegram Bot</p>
              <p class="font-serif text-2xl font-bold text-river-text mb-2">{clubConfig.telegram.bot}</p>
              <p class="text-river-muted text-sm mb-4">{t.hero.chipRate}</p>
              <p class="text-sm text-river-muted">
                Club ID: <span class="font-bold text-river-accent-bright">{clubConfig.clubId}</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
